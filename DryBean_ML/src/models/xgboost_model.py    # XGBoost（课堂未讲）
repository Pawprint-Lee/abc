"""
XGBoost模型 - 课堂未讲算法
参考文献: XGBoost在Dry Bean Dataset上可达92.88%准确率
"""

import xgboost as xgb
import numpy as np
import time
from .base import BaseModel


class XGBoostModel(BaseModel):
    """XGBoost分类器（课堂未讲）"""
    
    def __init__(self, random_state=42):
        super().__init__('XGBoost', random_state)
        self.eval_history = None
    
    def build_model(self, n_estimators=600, max_depth=4, learning_rate=0.15,
                    subsample=0.8, colsample_bytree=0.8, **kwargs):
        """构建XGBoost模型"""
        self.model = xgb.XGBClassifier(
            n_estimators=n_estimators,
            max_depth=max_depth,
            learning_rate=learning_rate,
            subsample=subsample,
            colsample_bytree=colsample_bytree,
            random_state=self.random_state,
            verbosity=0,
            use_label_encoder=False,
            eval_metric='mlogloss',
            **kwargs
        )
        return self.model
    
    def train(self, X_train, y_train, X_val=None, y_val=None, 
              early_stopping_rounds=50, eval_set_ratio=0.2, **kwargs):
        """
        训练XGBoost模型
        
        Args:
            X_train: 训练特征
            y_train: 训练标签
            X_val: 验证特征（可选）
            y_val: 验证标签（可选）
            early_stopping_rounds: 早停轮数
            eval_set_ratio: 从训练集划分验证集的比例
        """
        if self.model is None:
            self.build_model(**kwargs)
        
        # 准备验证集
        if X_val is None or y_val is None:
            # 从训练集划分
            split_idx = int(len(X_train) * (1 - eval_set_ratio))
            X_train_early = X_train[:split_idx]
            y_train_early = y_train[:split_idx]
            X_eval = X_train[split_idx:]
            y_eval = y_train[split_idx:]
        else:
            X_train_early = X_train
            y_train_early = y_train
            X_eval = X_val
            y_eval = y_val
        
        start_time = time.time()
        self.model.fit(
            X_train_early, y_train_early,
            eval_set=[(X_train_early, y_train_early), (X_eval, y_eval)],
            verbose=False
        )
        self.training_time = time.time() - start_time
        
        # 保存训练历史
        self.eval_history = self.model.evals_result()
        self.is_trained = True
        
        return self.model
    
    def predict(self, X):
        """预测"""
        if not self.is_trained:
            raise ValueError("模型尚未训练")
        return self.model.predict(X)
    
    def predict_proba(self, X):
        """预测概率"""
        if not self.is_trained:
            raise ValueError("模型尚未训练")
        return self.model.predict_proba(X)
    
    def get_eval_history(self):
        """获取训练历史（用于画Loss曲线）"""
        return self.eval_history
    
    def get_params(self):
        """获取模型参数"""
        return {
            'n_estimators': self.model.n_estimators if self.model else 600,
            'max_depth': self.model.max_depth if self.model else 4,
            'learning_rate': self.model.learning_rate if self.model else 0.15
        }
