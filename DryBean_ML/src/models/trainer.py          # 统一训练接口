"""
统一训练接口 - 管理所有模型的训练和评估
"""

import numpy as np
import pandas as pd
import time
from sklearn.metrics import accuracy_score, precision_score, recall_score, f1_score
import warnings
warnings.filterwarnings('ignore')

from .random_forest import RandomForestModel
from .xgboost_model import XGBoostModel
from .svm_model import SVMModel


class ModelTrainer:
    """统一模型训练器"""
    
    def __init__(self, random_state=42):
        self.random_state = random_state
        self.models = {}
        self.results = {}
        self.training_times = {}
        
    def get_all_models(self):
        """获取所有模型实例"""
        return {
            'Random Forest': RandomForestModel(self.random_state),
            'XGBoost': XGBoostModel(self.random_state),
            'SVM': SVMModel(self.random_state)
        }
    
    def train_all(self, X_train, y_train, X_val=None, y_val=None, **kwargs):
        """
        训练所有模型
        
        Returns:
            dict: 训练好的模型字典
        """
        print("\n" + "=" * 60)
        print("开始训练所有模型")
        print("=" * 60)
        
        model_classes = self.get_all_models()
        
        for name, model in model_classes.items():
            print(f"\n训练 {name}...")
            
            # 特殊处理XGBoost（需要验证集）
            if name == 'XGBoost' and X_val is not None:
                model.train(X_train, y_train, X_val=X_val, y_val=y_val, **kwargs)
            else:
                model.train(X_train, y_train, **kwargs)
            
            self.models[name] = model
            self.training_times[name] = model.get_training_time()
            
            print(f"✓ {name} 训练完成，耗时: {model.get_training_time():.2f}秒")
        
        return self.models
    
    def evaluate_model(self, model, X, y_true):
        """
        评估单个模型
        
        Returns:
            dict: 评估指标
        """
        y_pred = model.predict(X)
        
        metrics = {
            'Accuracy': accuracy_score(y_true, y_pred),
            'Precision': precision_score(y_true, y_pred, average='weighted'),
            'Recall': recall_score(y_true, y_pred, average='weighted'),
            'F1 Score': f1_score(y_true, y_pred, average='weighted')
        }
        
        return metrics, y_pred
    
    def evaluate_all(self, X_test, y_test, X_val=None, y_val=None):
        """
        评估所有模型
        
        Returns:
            dict: 所有模型的评估结果
        """
        print("\n" + "=" * 60)
        print("评估所有模型")
        print("=" * 60)
        
        results = {}
        
        for name, model in self.models.items():
            print(f"\n--- {name} ---")
            
            # 测试集评估
            test_metrics, y_pred = self.evaluate_model(model, X_test, y_test)
            results[name] = {
                'test': test_metrics,
                'y_pred': y_pred
            }
            
            # 如果有验证集，也评估验证集
            if X_val is not None and y_val is not None:
                val_metrics, _ = self.evaluate_model(model, X_val, y_val)
                results[name]['val'] = val_metrics
                print(f"验证集 - Acc: {val_metrics['Accuracy']:.4f}")
            
            print(f"测试集 - Acc: {test_metrics['Accuracy']:.4f}, "
                  f"F1: {test_metrics['F1 Score']:.4f}")
        
        self.results = results
        return results
    
    def get_results_dataframe(self):
        """
        获取结果DataFrame
        """
        rows = []
        for name, result in self.results.items():
            if 'test' in result:
                row = {
                    'Algorithm': name,
                    'Accuracy': f"{result['test']['Accuracy']:.4f}",
                    'Precision': f"{result['test']['Precision']:.4f}",
                    'Recall': f"{result['test']['Recall']:.4f}",
                    'F1 Score': f"{result['test']['F1 Score']:.4f}",
                    'Training Time (s)': f"{self.training_times.get(name, 0):.2f}"
                }
                rows.append(row)
        
        return pd.DataFrame(rows)
    
    def get_xgboost_history(self):
        """获取XGBoost训练历史"""
        if 'XGBoost' in self.models:
            return self.models['XGBoost'].get_eval_history()
        return None
