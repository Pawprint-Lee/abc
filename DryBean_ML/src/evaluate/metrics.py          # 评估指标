"""
评估指标模块 - 计算和可视化各种评估指标
"""

import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.metrics import confusion_matrix, classification_report
import os


class MetricsVisualizer:
    """评估指标可视化"""
    
    def __init__(self, output_dir='experiments/figures'):
        self.output_dir = output_dir
        os.makedirs(output_dir, exist_ok=True)
        
        # 设置绘图风格
        plt.rcParams['font.sans-serif'] = ['SimHei', 'Arial Unicode MS', 'DejaVu Sans']
        plt.rcParams['axes.unicode_minus'] = False
    
    def plot_accuracy_comparison(self, results, save=True):
        """
        绘制精度对比图
        
        Args:
            results: 评估结果字典
            save: 是否保存
        """
        names = list(results.keys())
        test_acc = [results[n]['test']['Accuracy'] for n in names]
        
        # 检查是否有验证集结果
        has_val = 'val' in results[names[0]]
        if has_val:
            val_acc = [results[n]['val']['Accuracy'] for n in names]
        
        x = np.arange(len(names))
        width = 0.35
        
        fig, ax = plt.subplots(figsize=(10, 6))
        
        if has_val:
            bars1 = ax.bar(x - width/2, val_acc, width, label='验证集', color='skyblue')
            bars2 = ax.bar(x + width/2, test_acc, width, label='测试集', color='coral')
        else:
            bars = ax.bar(x, test_acc, width, color='coral')
        
        ax.set_xlabel('算法', fontsize=12)
        ax.set_ylabel('准确率', fontsize=12)
        ax.set_title('各算法精度对比', fontsize=14, fontweight='bold')
        ax.set_xticks(x)
        ax.set_xticklabels(names)
        ax.legend()
        ax.set_ylim(0.7, 1.0)
        ax.grid(True, alpha=0.3, axis='y')
        
        # 添加数值标签
        if has_val:
            for bar in bars1:
                ax.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 0.005,
                        f'{bar.get_height():.3f}', ha='center', va='bottom', fontsize=9)
            for bar in bars2:
                ax.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 0.005,
                        f'{bar.get_height():.3f}', ha='center', va='bottom', fontsize=9)
        else:
            for bar in bars:
                ax.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 0.005,
                        f'{bar.get_height():.3f}', ha='center', va='bottom', fontsize=9)
        
        plt.tight_layout()
        
        if save:
            save_path = os.path.join(self.output_dir, 'accuracy_comparison.png')
            plt.savefig(save_path, dpi=300, bbox_inches='tight')
            print(f"✓ 精度对比图已保存: {save_path}")
        
        plt.show()
        return fig
    
    def plot_loss_curves(self, history, save=True):
        """
        绘制Loss曲线（仅适用于XGBoost）
        
        Args:
            history: XGBoost训练历史
            save: 是否保存
        """
        if history is None:
            print("⚠️ 无训练历史数据")
            return
        
        fig, ax = plt.subplots(figsize=(10, 6))
        
        if 'validation_0' in history and 'mlogloss' in history['validation_0']:
            ax.plot(history['validation_0']['mlogloss'], label='训练集', linewidth=2)
        if 'validation_1' in history and 'mlogloss' in history['validation_1']:
            ax.plot(history['validation_1']['mlogloss'], label='验证集', linewidth=2)
        
        ax.set_xlabel('迭代轮次', fontsize=12)
        ax.set_ylabel('多分类交叉熵损失 (mlogloss)', fontsize=12)
        ax.set_title('XGBoost 训练损失曲线', fontsize=14, fontweight='bold')
        ax.legend()
        ax.grid(True, alpha=0.3)
        
        plt.tight_layout()
        
        if save:
            save_path = os.path.join(self.output_dir, 'loss_curves.png')
            plt.savefig(save_path, dpi=300, bbox_inches='tight')
            print(f"✓ Loss曲线已保存: {save_path}")
        
        plt.show()
        return fig
    
    def plot_confusion_matrix(self, y_true, y_pred, class_names, model_name, save=True):
        """绘制混淆矩阵"""
        cm = confusion_matrix(y_true, y_pred)
        
        fig, ax = plt.subplots(figsize=(8, 6))
        sns.heatmap(cm, annot=True, fmt='d', cmap='Blues',
                   xticklabels=class_names, yticklabels=class_names, ax=ax)
        ax.set_xlabel('预测类别', fontsize=12)
        ax.set_ylabel('真实类别', fontsize=12)
        ax.set_title(f'{model_name} 混淆矩阵', fontsize=14, fontweight='bold')
        
        plt.tight_layout()
        
        if save:
            save_path = os.path.join(self.output_dir, f'confusion_matrix_{model_name.replace(" ", "_")}.png')
            plt.savefig(save_path, dpi=300, bbox_inches='tight')
            print(f"✓ 混淆矩阵已保存: {save_path}")
        
        plt.show()
        return fig
    
    def plot_robustness_comparison(self, robustness_results, save=True):
        """
        绘制鲁棒性分析图
        
        Args:
            robustness_results: 鲁棒性测试结果DataFrame
            save: 是否保存
        """
        fig, ax = plt.subplots(figsize=(12, 6))
        
        for col in robustness_results.columns:
            ax.plot(robustness_results.index, robustness_results[col], 
                   marker='o', label=col, linewidth=2)
        
        ax.set_xlabel('噪声类型和强度', fontsize=12)
        ax.set_ylabel('准确率', fontsize=12)
        ax.set_title('各算法鲁棒性对比（噪声影响）', fontsize=14, fontweight='bold')
        ax.legend()
        ax.grid(True, alpha=0.3)
        ax.set_ylim(0.5, 1.0)
        
        plt.xticks(rotation=20)
        plt.tight_layout()
        
        if save:
            save_path = os.path.join(self.output_dir, 'robustness_analysis.png')
            plt.savefig(save_path, dpi=300, bbox_inches='tight')
            print(f"✓ 鲁棒性分析图已保存: {save_path}")
        
        plt.show()
        return fig
